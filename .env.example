# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WDK Node.js microservice (wdk-service/index.js) ─────────────────────────
# These are READ by the Node.js service to initialise the WDK wallet
WDK_SEED_PHRASE=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
WDK_RPC_URL=https://polygon-rpc.com
WDK_CHAIN=polygon
WDK_SERVICE_PORT=3001

# ── WDK wallet (Python backend → microservice) ───────────────────────────────
# These are READ by the Python backend to call the WDK microservice
WDK_ENDPOINT=http://localhost:3001
WDK_API_KEY=your-shared-secret
WDK_WALLET_ADDRESS=0x...

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./tipmind.db

# ── Tipping defaults ─────────────────────────────────────────────────────────
MAX_TIP_PER_VIDEO=5.00
DEFAULT_TOKEN=USDT

# ── Autonomous poller ────────────────────────────────────────────────────────
# Comma-separated YouTube channel IDs to watch autonomously.
# Leave empty to use built-in demo channels (MKBHD, t3.gg, Coin Bureau, Dave2D).
YOUTUBE_CHANNEL_IDS=

# YouTube Data API v3 — enables real engagement scoring from actual video stats.
# Free quota is 10,000 units/day; each video fetch costs 1 unit.
# Get a key: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Without this key, TipMind falls back to heuristic engagement scoring.
YOUTUBE_API_KEY=

# ── Demo recipient ────────────────────────────────────────────────────────────
# All on-chain tips route here (YouTube channel IDs aren't EVM addresses).
# Set to any Polygon wallet you control — can be a second MetaMask account.
DEMO_RECIPIENT_ADDRESS=
